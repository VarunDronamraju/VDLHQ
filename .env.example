# Database Configuration
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# AI Integration (Groq)
GROQ_API_KEY=your_groq_api_key_here

# LLM Providers (Multi-failover pipeline)
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT Authentication
JWT_SECRET=your_32_byte_hex_secret_here
JWT_ALGORITHM=HS256

# Automation Hooks (Optional/Stubs)
SLACK_WEBHOOK_URL=your_slack_webhook_here
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Gmail Automation (Optional/Stubs)
GMAIL_USER=your_gmail_address_here
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Redis (Optional)
REDIS_URL=redis://default:password@host:port
